{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": [
      "react",
      "react-native",
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@components": [
        "src/components/index"
      ],
      "@components/*": [
        "src/components/*"
      ],
      "@screens": [
        "src/screens/index"
      ],
      "@screens/*": [
        "src/screens/*"
      ],
      "@services": [
        "src/services/index"
      ],
      "@services/*": [
        "src/services/*"
      ],
      "@hooks": [
        "src/hooks/index"
      ],
      "@hooks/*": [
        "src/hooks/*"
      ],
      "@types": [
        "src/types/index"
      ],
      "@types/*": [
        "src/types/*"
      ],
      "@utils": [
        "src/utils/index"
      ],
      "@utils/*": [
        "src/utils/*"
      ],
      "@navigation": [
        "src/navigation/index"
      ],
      "@navigation/*": [
        "src/navigation/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules"
  ],
  "extends": "expo/tsconfig.base"
}
